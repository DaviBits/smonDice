000001c0 <tft_writeData>:
// =============================================
// COLOR RGB ? RGB565
// =============================================
uint16_t ILI9341_color565(uint8_t r, uint8_t g, uint8_t b) {
	return ((r & 0xF8) << 8) | ((g & 0xFC) << 3) | (b >> 3);
}
